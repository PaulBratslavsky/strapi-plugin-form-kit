{
  "name": "strapi-plugin-form-kit",
  "version": "0.4.1",
  "description": "Native Strapi v5 plugin for building, embedding, and managing forms — drag-and-drop builder, AI-assisted creation, submissions inbox, notifications, webhooks.",
  "license": "MIT",
  "author": "Paul Bratslavsky",
  "homepage": "https://github.com/PaulBratslavsky/strapi-plugin-form-kit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PaulBratslavsky/strapi-plugin-form-kit.git",
    "directory": "packages/plugin"
  },
  "bugs": {
    "url": "https://github.com/PaulBratslavsky/strapi-plugin-form-kit/issues"
  },
  "keywords": [
    "strapi",
    "strapi-plugin",
    "plugin",
    "strapi-v5",
    "forms",
    "form-builder",
    "embed",
    "submissions",
    "notifications",
    "webhooks",
    "ai",
    "ollama",
    "anthropic",
    "openai"
  ],
  "type": "commonjs",
  "exports": {
    "./package.json": "./package.json",
    "./strapi-admin": {
      "types": "./dist/admin/src/index.d.ts",
      "source": "./admin/src/index.ts",
      "import": "./dist/admin/index.mjs",
      "require": "./dist/admin/index.js",
      "default": "./dist/admin/index.js"
    },
    "./strapi-server": {
      "types": "./dist/server/src/index.d.ts",
      "source": "./server/src/index.ts",
      "import": "./dist/server/index.mjs",
      "require": "./dist/server/index.js",
      "default": "./dist/server/index.js"
    }
  },
  "files": [
    "dist",
    "admin/src",
    "server/src",
    "strapi-admin.js",
    "strapi-server.js",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "pnpm run build:embed && strapi-plugin build && pnpm run build:types && pnpm run copy:embed",
    "build:embed": "pnpm -F @strapi-forms/embed build",
    "build:types": "tsc --emitDeclarationOnly --declarationMap --outDir dist || true",
    "copy:embed": "mkdir -p dist/embed && cp ../embed/dist/embed.iife.js dist/embed/embed.js && cp ../embed/dist/embed.iife.js.map dist/embed/embed.js.map 2>/dev/null || true",
    "watch": "strapi-plugin watch",
    "watch:link": "strapi-plugin watch:link",
    "verify": "strapi-plugin verify",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx --max-warnings 0 || true",
    "release": "pnpm run build && pnpm run verify && pnpm publish",
    "release:dry": "pnpm run build && pnpm run verify && pnpm pack"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.1",
    "@codemirror/lang-html": "^6.4.11",
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-popover": "^1.1.15",
    "@uiw/react-codemirror": "^4.25.9",
    "bullmq": "^5.30.0",
    "ioredis": "^5.4.1",
    "openai": "^6.37.0",
    "react-colorful": "^5.7.0",
    "uuid": "^11.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@strapi-forms/embed": "workspace:*",
    "@strapi/design-system": "^2.0.0-rc.20",
    "@strapi/icons": "^2.0.0-rc.20",
    "@strapi/sdk-plugin": "^5.3.2",
    "@strapi/strapi": "^5.0.0",
    "@strapi/typescript-utils": "^5.0.0",
    "@strapi/utils": "^5.0.0",
    "@types/node": "^20.16.10",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-router-dom": "^5.3.3",
    "@types/uuid": "^10.0.0",
    "prettier": "^3.3.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-intl": "^10.1.7",
    "react-router-dom": "^7.15.1",
    "styled-components": "^6.1.13",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  },
  "peerDependencies": {
    "@strapi/design-system": "^2.0.0",
    "@strapi/icons": "^2.0.0",
    "@strapi/sdk-plugin": "^5.0.0",
    "@strapi/strapi": "^5.0.0",
    "@strapi/utils": "^5.0.0",
    "react": "^17.0.0 || ^18.0.0",
    "react-dom": "^17.0.0 || ^18.0.0",
    "react-intl": "^6.0.0 || ^7.0.0",
    "react-router-dom": "^5.2.0 || ^6.0.0",
    "styled-components": "^5.2.1 || ^6.0.0"
  },
  "strapi": {
    "kind": "plugin",
    "name": "forms",
    "displayName": "Forms",
    "description": "Build, embed, and manage forms inside Strapi."
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
