{
  "name": "@strapi-forms/embed",
  "version": "0.1.0",
  "description": "Lightweight embed snippet for the Strapi Forms plugin. Renders any form built with Strapi Forms onto any HTML page.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/embed.js",
  "module": "./dist/embed.mjs",
  "browser": "./dist/embed.iife.js",
  "types": "./dist/embed.d.ts",
  "exports": {
    ".": {
      "types": "./dist/embed.d.ts",
      "import": "./dist/embed.mjs",
      "require": "./dist/embed.js",
      "default": "./dist/embed.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build && tsc --emitDeclarationOnly --outDir dist",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts --max-warnings 0 || true",
    "size": "node ./scripts/check-bundle-size.mjs"
  },
  "devDependencies": {
    "@types/node": "^20.16.10",
    "jsdom": "^29.1.1",
    "typescript": "^5.6.3",
    "vite": "^8.0.13",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "^2.1.4"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
