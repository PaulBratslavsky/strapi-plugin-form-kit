{
  "name": "strapi-forms-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Strapi Forms — a native Strapi v5 plugin for building, embedding, and managing forms",
  "license": "MIT",
  "packageManager": "pnpm@10.28.1",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "./scripts/start.sh",
    "dev": "./scripts/start.sh",
    "dev:watch": "./scripts/start.sh --watch",
    "build": "./scripts/build.sh",
    "build:packages": "pnpm -r --filter ./packages/* build",
    "test": "pnpm -r --filter ./packages/* test",
    "lint": "pnpm -r --filter ./packages/* lint",
    "typecheck": "pnpm -r --filter ./packages/* typecheck",
    "dev:plugin": "pnpm --filter strapi-plugin-forms watch",
    "dev:embed": "pnpm --filter @strapi-forms/embed dev",
    "dev:test-app": "pnpm --filter test-app develop"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
